#!/bin/bash
# dev-keys: Manage API keys in macOS Keychain
# Keys are stored as generic passwords with service="dev-api-keys"
#
# Install globally:  npm install -g @allofus/dev-keys
# Or link locally:   ln -sf "$(pwd)/bin/dev-keys" /usr/local/bin/dev-keys

set -euo pipefail

VERSION="0.1.0"
SERVICE="dev-api-keys"

# ── Terminal capability detection ────────────────────────────────────

# Detect terminal width (default 80)
TERM_COLS="${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}"

# Determine if this terminal is "dumb" (no escape support)
_is_dumb() {
  [[ "${TERM:-}" == "dumb" ]] || [[ "${TERM:-}" == "emacs" ]] || [[ -z "${TERM:-}" ]]
}

# Determine color support following the standard hierarchy:
#   1. NO_COLOR (https://no-color.org) — always wins, disables color
#   2. CLICOLOR_FORCE — force color even when not a tty (macOS/BSD convention)
#   3. TERM=dumb — no escape sequences at all
#   4. Piped output — disable color unless forced
#   5. Otherwise, enable color
_use_color() {
  # NO_COLOR takes absolute precedence
  [[ -n "${NO_COLOR:-}" ]] && return 1
  # CLICOLOR_FORCE overrides tty/dumb checks
  [[ -n "${CLICOLOR_FORCE:-}" ]] && return 0
  # Dumb terminals can't render escapes
  _is_dumb && return 1
  # CLICOLOR=0 explicitly disables
  [[ "${CLICOLOR:-1}" == "0" ]] && return 1
  # Not a tty → no color (unless forced above)
  [ -t 2 ] || return 1
  return 0
}

# Determine if we can use Unicode glyphs
_use_unicode() {
  _is_dumb && return 1
  # Check locale for UTF-8 support
  case "${LC_ALL:-${LC_CTYPE:-${LANG:-}}}" in
    *UTF-8*|*utf-8*|*utf8*) return 0 ;;
  esac
  # If locale doesn't say, check TERM — modern terminals generally support it
  [[ -n "${TERM:-}" ]] && return 0
  return 1
}

if _use_color; then
  BOLD="\033[1m"   DIM="\033[2m"    RESET="\033[0m"
  GREEN="\033[32m" RED="\033[31m"   YELLOW="\033[33m" CYAN="\033[36m"
else
  BOLD=""  DIM=""  RESET=""  GREEN=""  RED=""  YELLOW=""  CYAN=""
fi

if _use_unicode; then
  SYM_OK="✓"  SYM_ERR="✗"  SYM_BULLET="·"  SYM_KEY="🔑"
else
  SYM_OK="OK"  SYM_ERR="ERR"  SYM_BULLET="-"  SYM_KEY="*"
fi

ok()   { printf "${GREEN}${SYM_OK}${RESET} %s\n" "$*" >&2; }
err()  { printf "${RED}${SYM_ERR}${RESET} %s\n" "$*" >&2; }
info() { printf "${DIM}%s${RESET}\n" "$*" >&2; }

# ── Usage ────────────────────────────────────────────────────────────

usage() {
  if _is_dumb; then
    # Plain-text help for dumb terminals / piped output
    cat <<'EOF'
dev-keys — API keys in macOS Keychain

USAGE
  dev-keys <command> [args]

COMMANDS
  set <name> [value]     Store a key (prompts securely if value omitted)
  get <name>             Print a key to stdout
  delete <name>          Remove a key from Keychain
  list                   List all stored key names
  env [names...]         Print export statements for shell eval
  init                   Print shell startup script for .zshrc/.bashrc
  show <name>            Print key name + masked value
  ui                     Open setup panel in your browser

OPTIONS
  --help, -h             Show this help
  --version, -v          Print version

EXAMPLES
  dev-keys set openrouter sk-or-abc123
  dev-keys get openrouter
  eval "$(dev-keys env)"
  eval "$(dev-keys init)"
  with-key openrouter npm start
EOF
  else
    cat <<EOF
${BOLD}dev-keys${RESET} ${DIM}v${VERSION}${RESET} — API keys in macOS Keychain

${BOLD}USAGE${RESET}
  dev-keys <command> [args]

${BOLD}COMMANDS${RESET}
  ${CYAN}set${RESET} <name> [value]     Store a key (prompts securely if value omitted)
  ${CYAN}get${RESET} <name>             Print a key to stdout
  ${CYAN}delete${RESET} <name>          Remove a key from Keychain
  ${CYAN}list${RESET}                   List all stored key names
  ${CYAN}env${RESET} [names...]         Print export statements for shell eval
  ${CYAN}init${RESET}                   Print shell startup script for .zshrc/.bashrc
  ${CYAN}show${RESET} <name>            Print key name + masked value
  ${CYAN}ui${RESET}                     Open setup panel in your browser

${BOLD}OPTIONS${RESET}
  --help, -h              Show this help
  --version, -v           Print version

${BOLD}EXAMPLES${RESET}
  ${DIM}# Store a key${RESET}
  dev-keys set openrouter sk-or-abc123
  dev-keys set anthropic                   ${DIM}# prompts for value${RESET}

  ${DIM}# Use in scripts${RESET}
  curl -H "Authorization: Bearer \$(dev-keys get openrouter)" ...

  ${DIM}# Load all keys as env vars${RESET}
  eval "\$(dev-keys env)"

  ${DIM}# Add to .zshrc for automatic loading${RESET}
  eval "\$(dev-keys init)"

  ${DIM}# Run a command with a key injected (requires init)${RESET}
  with-key openrouter npm start

${BOLD}SHELL ONE-LINERS${RESET} ${DIM}(no dev-keys install needed)${RESET}
  export OPENROUTER_API_KEY=\$(security find-generic-password -s dev-api-keys -a openrouter -w)
EOF
  fi
  exit "${1:-0}"
}

# ── Commands ─────────────────────────────────────────────────────────

cmd_set() {
  local name="${1:?$(err "Missing key name"; echo "Usage: dev-keys set <name> [value]"; exit 1)}"
  local value="${2:-}"

  if [ -z "$value" ]; then
    if [ -t 0 ]; then
      printf "${BOLD}Enter value for ${CYAN}%s${RESET}: " "$name" >&2
      # -s (silent) may not work on all terminals; fall back to plain read
      if _is_dumb; then
        read -r value
      else
        read -rs value
        echo >&2
      fi
    else
      # Reading from pipe/redirect — no prompt needed
      read -r value
    fi
  fi

  if [ -z "$value" ]; then
    err "Empty value — nothing stored"
    exit 1
  fi

  # Delete existing entry if present (security add fails on duplicates)
  security delete-generic-password -s "$SERVICE" -a "$name" >/dev/null 2>&1 || true
  security add-generic-password -s "$SERVICE" -a "$name" -w "$value" -U
  ok "Stored ${BOLD}${name}${RESET}"
}

cmd_get() {
  local name="${1:?$(err "Missing key name"; echo "Usage: dev-keys get <name>"; exit 1)}"
  security find-generic-password -s "$SERVICE" -a "$name" -w 2>/dev/null || {
    err "Key '${name}' not found"
    info "Store it with: dev-keys set ${name}"
    exit 1
  }
}

cmd_show() {
  local name="${1:?$(err "Missing key name"; echo "Usage: dev-keys show <name>"; exit 1)}"
  local value
  value=$(security find-generic-password -s "$SERVICE" -a "$name" -w 2>/dev/null) || {
    err "Key '${name}' not found"
    exit 1
  }
  local len=${#value}
  local visible=4
  if [ "$len" -le 8 ]; then visible=2; fi
  # Adapt mask length to terminal width (name col + gap + mask)
  local name_col=20
  local max_mask=$(( TERM_COLS - name_col - 2 ))
  if [ "$max_mask" -lt 8 ]; then max_mask=8; fi
  local mask_len=$(( len - visible ))
  if [ "$mask_len" -gt "$max_mask" ]; then mask_len=$max_mask; fi
  local masked="${value:0:$visible}$(printf '%*s' "$mask_len" '' | tr ' ' '*')"
  printf "${CYAN}%-${name_col}s${RESET} %s\n" "$name" "$masked"
}

cmd_delete() {
  local name="${1:?$(err "Missing key name"; echo "Usage: dev-keys delete <name>"; exit 1)}"

  # Confirm if interactive terminal
  if [ -t 0 ]; then
    printf "${YELLOW}Delete${RESET} ${BOLD}%s${RESET} from Keychain? [y/N] " "$name" >&2
    read -r confirm
    case "$confirm" in
      y|Y|yes|YES) ;;
      *) info "Cancelled"; exit 0 ;;
    esac
  fi

  security delete-generic-password -s "$SERVICE" -a "$name" >/dev/null 2>&1 || {
    err "Key '${name}' not found"
    exit 1
  }
  ok "Deleted ${BOLD}${name}${RESET}"
}

cmd_list() {
  local names
  names=$(
    security dump-keychain 2>/dev/null | \
      grep -A4 "0x00000007 <blob>=\"$SERVICE\"" | \
      grep '"acct"<blob>=' | \
      sed 's/.*="\([^"]*\)".*/\1/' | \
      sort -u
  )

  if [ -z "$names" ]; then
    info "No keys stored. Add one with: dev-keys set <name>"
    exit 0
  fi

  local count
  count=$(echo "$names" | wc -l | tr -d ' ')
  info "${count} key(s) in Keychain:"
  echo "$names" | while IFS= read -r name; do
    printf "  ${CYAN}%s${RESET}\n" "$name"
  done
}

cmd_env() {
  local names=("$@")
  if [ ${#names[@]} -eq 0 ]; then
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      names+=("$name")
    done < <(
      security dump-keychain 2>/dev/null | \
        grep -A4 "0x00000007 <blob>=\"$SERVICE\"" | \
        grep '"acct"<blob>=' | \
        sed 's/.*="\([^"]*\)".*/\1/' | \
        sort -u
    )
  fi

  for name in "${names[@]}"; do
    local value
    value=$(security find-generic-password -s "$SERVICE" -a "$name" -w 2>/dev/null) || continue
    local env_name
    env_name=$(echo "$name" | tr '[:lower:]-' '[:upper:]_')
    echo "export ${env_name}_API_KEY='${value}'"
  done
}

cmd_init() {
  cat <<'INITEOF'
# dev-keys: load API keys from macOS Keychain into environment
# Add this line to your .zshrc or .bashrc:
#   eval "$(dev-keys init)"

_dk_get() { security find-generic-password -s dev-api-keys -a "$1" -w 2>/dev/null; }

# Load all stored keys as <NAME>_API_KEY env vars
eval "$(dev-keys env 2>/dev/null)"

# Helper: run any command with a key injected
# Usage: with-key openrouter npm start
with-key() {
  local name="$1"; shift
  local env_name
  env_name=$(echo "$name" | tr '[:lower:]-' '[:upper:]_')
  export "${env_name}_API_KEY=$(_dk_get "$name")"
  "$@"
}
INITEOF
}

# ── Dispatch ─────────────────────────────────────────────────────────

cmd_ui() {
  # Resolve the web server script relative to this script's location
  local script_dir
  script_dir="$(cd "$(dirname "$0")/.." && pwd)"
  local server="${script_dir}/dist/web-server.js"

  if [ ! -f "$server" ]; then
    err "Web server not built. Run: cd ${script_dir} && npm run build"
    exit 1
  fi

  exec node "$server" "$@"
}

case "${1:-}" in
  set)       shift; cmd_set "$@" ;;
  get)       shift; cmd_get "$@" ;;
  show)      shift; cmd_show "$@" ;;
  delete|rm) shift; cmd_delete "$@" ;;
  list|ls)   cmd_list ;;
  env)       shift; cmd_env "$@" ;;
  init)      cmd_init ;;
  ui)        shift; cmd_ui "$@" ;;
  --version|-v) echo "dev-keys ${VERSION}" ;;
  --help|-h)    usage 0 ;;
  "")           usage 0 ;;
  *)            err "Unknown command: $1"; echo; usage 1 ;;
esac
